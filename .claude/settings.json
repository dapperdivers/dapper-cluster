{
  "permissions": {
    "allow": [
      "Bash(kubectl get *)",
      "Bash(kubectl describe *)",
      "Bash(kubectl logs *)",
      "Bash(kubectl top *)",
      "Bash(kubectl config get-contexts *)",
      "Bash(flux get *)",
      "Bash(flux stats *)",
      "Bash(talosctl get *)",
      "Bash(talosctl health *)",
      "Bash(talosctl version *)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/link-worktree-creds.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/block-branch-switch.sh"
          }
        ]
      }
    ]
  }
}
