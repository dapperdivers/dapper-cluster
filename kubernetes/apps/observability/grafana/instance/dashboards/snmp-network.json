{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "title": "Network / SNMP",
  "uid": "snmp-network",
  "tags": ["network", "snmp"],
  "timezone": "",
  "schemaVersion": 39,
  "time": { "from": "now-3h", "to": "now" },
  "refresh": "1m",
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0,
        "label": "Datasource"
      },
      {
        "name": "device",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": "label_values(ifHCInOctets, target)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" },
        "label": "Device",
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "type": "stat",
      "title": "Devices reporting",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [{ "refId": "A", "expr": "count(count by (target) (ifIndex))" }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": []
      },
      "options": { "colorMode": "value", "graphMode": "none", "textMode": "value" }
    },
    {
      "type": "stat",
      "title": "Interfaces up",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [{ "refId": "A", "expr": "count(ifOperStatus{target=~\"$device\"} == 1)" }],
      "fieldConfig": {
        "defaults": { "color": { "mode": "fixed", "fixedColor": "green" } },
        "overrides": []
      },
      "options": { "colorMode": "value", "graphMode": "none", "textMode": "value" }
    },
    {
      "type": "stat",
      "title": "Interfaces down (admin-up)",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "count((ifOperStatus{target=~\"$device\"} == 2) and on (instance, ifIndex) (ifAdminStatus == 1)) or vector(0)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "value" }
    },
    {
      "type": "stat",
      "title": "Total error+discard rate",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(ifInErrors{target=~\"$device\"}[5m]) + rate(ifOutErrors{target=~\"$device\"}[5m]) + rate(ifInDiscards{target=~\"$device\"}[5m]) + rate(ifOutDiscards{target=~\"$device\"}[5m]))"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "pps",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 5 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "area", "textMode": "value" }
    },
    {
      "type": "stat",
      "title": "OPNsense load (1m)",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [{ "refId": "A", "expr": "laLoadFloat{target=\"opnsense\", laNames=\"Load-1\"}" }],
      "fieldConfig": {
        "defaults": {
          "decimals": 2,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 4 },
              { "color": "red", "value": 8 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "colorMode": "value", "graphMode": "area", "textMode": "value" }
    },
    {
      "type": "timeseries",
      "title": "Inbound throughput",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "topk(15, rate(ifHCInOctets{target=~\"$device\"}[5m]) * 8)",
          "legendFormat": "{{target}} {{ifName}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bps",
          "custom": { "drawStyle": "line", "fillOpacity": 10, "showPoints": "never" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["max", "mean"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "type": "timeseries",
      "title": "Outbound throughput",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "topk(15, rate(ifHCOutOctets{target=~\"$device\"}[5m]) * 8)",
          "legendFormat": "{{target}} {{ifName}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bps",
          "custom": { "drawStyle": "line", "fillOpacity": 10, "showPoints": "never" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["max", "mean"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "type": "timeseries",
      "title": "Interface errors + discards",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 13 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "topk(15, rate(ifInErrors{target=~\"$device\"}[5m]) + rate(ifOutErrors{target=~\"$device\"}[5m]) + rate(ifInDiscards{target=~\"$device\"}[5m]) + rate(ifOutDiscards{target=~\"$device\"}[5m])) > 0",
          "legendFormat": "{{target}} {{ifName}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "pps",
          "custom": { "drawStyle": "line", "fillOpacity": 10, "showPoints": "auto" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["max", "mean"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "type": "table",
      "title": "Interface status",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 13 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "ifOperStatus{target=~\"$device\"}",
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "job": true,
              "instance": true,
              "ifIndex": true,
              "ifDescr": true
            },
            "renameByName": {
              "target": "Device",
              "ifName": "Interface",
              "ifAlias": "Description",
              "Value": "Status"
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Status" },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "1": { "text": "Up", "color": "green", "index": 0 },
                      "2": { "text": "Down", "color": "red", "index": 1 },
                      "3": { "text": "Testing", "index": 2 }
                    }
                  }
                ]
              },
              { "id": "custom.cellOptions", "value": { "type": "color-text" } }
            ]
          }
        ]
      },
      "options": { "showHeader": true, "sortBy": [{ "displayName": "Device", "desc": false }] }
    }
  ]
}
