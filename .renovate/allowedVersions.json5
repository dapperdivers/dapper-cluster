{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  packageRules: [
    {
      matchDatasources: ["docker"],
      matchPackageNames: ["ghcr.io/linuxserver/calibre-web"],
      allowedVersions: "<1",
    },
    {
      // Pin Ceph images to v18.x to match external Ceph cluster version (18.2.7)
      // Prevents automatic upgrades to v19+ which would be incompatible
      // Applies to: toolbox and CephCluster cephVersion.image
      matchDatasources: ["docker"],
      matchPackageNames: ["quay.io/ceph/ceph"],
      matchFileNames: [
        "kubernetes/apps/rook-ceph/rook-ceph-cluster/app/toolbox.yaml",
        "kubernetes/apps/rook-ceph/rook-ceph-cluster/app/cluster-external.yaml"
      ],
      allowedVersions: "/^v18\\./",
    },
    {
      // Pin emqx-operator to 2.2.29 - 2.3.0 crashes on /api/v5/load_rebalance/global_status
      // (HTTP 404), sets readiness gate apps.emqx.io/on-serving=False, drains listeners endpoints.
      matchDatasources: ["helm"],
      matchPackageNames: ["emqx-operator"],
      allowedVersions: "<=2.2.29",
    },
    {
      // Pin EMQX broker to 5.8.x - 5.9+ requires operator 2.3.0+ (broken), 6.x is enterprise-only.
      matchDatasources: ["docker"],
      matchPackageNames: ["public.ecr.aws/emqx/emqx"],
      allowedVersions: "/^5\\.8\\./",
    },
  ],
}
